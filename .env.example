# =============================================================================
# Aerlix Regulated Delivery Control Plane — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before running.
# NEVER commit the actual .env file to version control.
# =============================================================================

# ---------------------------
# Application
# ---------------------------
APP_ENV=development
APP_NAME="Aerlix Control Plane"
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-32-byte-hex-string-in-production

# ---------------------------
# Database
# ---------------------------
DATABASE_URL=postgresql+asyncpg://aerlix:aerlix_dev_password@localhost:5432/aerlix_control_plane
DATABASE_URL_SYNC=postgresql://aerlix:aerlix_dev_password@localhost:5432/aerlix_control_plane

# ---------------------------
# Redis / Celery
# ---------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------
# API Configuration
# ---------------------------
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ---------------------------
# Authentication (JWT)
# ---------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------
# Audit / Export
# ---------------------------
AUDIT_BUNDLE_OUTPUT_DIR=/tmp/aerlix-audit-bundles
EVIDENCE_STORAGE_DIR=/tmp/aerlix-evidence

# ---------------------------
# Compliance Baseline
# ---------------------------
DEFAULT_COMPLIANCE_FRAMEWORK=NIST-800-53-Rev5
REQUIRED_CONTROL_BASELINE=moderate
